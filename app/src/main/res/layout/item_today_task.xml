<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/shape_card"
    android:backgroundTint="@color/white"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:elevation="2dp">

    <!-- CHỖ NÀY SỬA: ĐƯA HỘP ICON LÊN ĐẦU ĐỂ KHAI BÁO ID TRƯỚC -->
    <ImageView
        android:id="@+id/imgCategoryIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/shape_status_done"
        android:backgroundTint="#FCE4EC"
        android:padding="7dp"
        android:src="@drawable/outline_work_24"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Danh mục nhóm dự án -->
    <TextView
        android:id="@+id/tvCategory"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/grey_text"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/imgCategoryIcon"/>

    <!-- Tiêu đề chi tiết công việc -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCategory"
        app:layout_constraintEnd_toStartOf="@id/imgCategoryIcon"/>

    <!-- Mốc thời gian (Icon đồng hồ + Text) -->
    <LinearLayout
        android:id="@+id/layoutTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">
        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@android:drawable/ic_menu_recent_history"
            app:tint="#9A7BFF"
            android:layout_marginEnd="6dp"/>
        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#9A7BFF"
            android:textSize="13sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Thẻ Trạng thái bo góc dưới bên phải -->
    <TextView
        android:id="@+id/tvStatusBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="10dp"
        android:paddingVertical="3dp"
        android:textSize="11sp"
        android:textStyle="bold"
        android:background="@drawable/shape_status_done"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgCategoryIcon"/>

</androidx.constraintlayout.widget.ConstraintLayout>