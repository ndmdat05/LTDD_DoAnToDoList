<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/today_task_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="90dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="4dp"
                    android:src="@android:drawable/ic_media_previous"
                    app:tint="@color/black" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Today's Tasks"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:src="@android:drawable/ic_popup_reminder"
                    app:tint="@color/black" />
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="52dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_card"
                    android:backgroundTint="@color/white"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="May" android:textColor="@color/grey_text" android:textSize="11sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="23" android:textColor="@color/black" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fri" android:textColor="@color/grey_text" android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="52dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_card"
                    android:backgroundTint="@color/white"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="May" android:textColor="@color/grey_text" android:textSize="11sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="24" android:textColor="@color/black" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sat" android:textColor="@color/grey_text" android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="58dp"
                    android:layout_height="90dp"
                    android:background="@drawable/shape_card"
                    android:backgroundTint="@color/purple_primary"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp"
                    android:elevation="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="May" android:textColor="#EEE" android:textSize="11sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="25" android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sun" android:textColor="#EEE" android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="52dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_card"
                    android:backgroundTint="@color/white"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="May" android:textColor="@color/grey_text" android:textSize="11sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="26" android:textColor="@color/black" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mon" android:textColor="@color/grey_text" android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="52dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_card"
                    android:backgroundTint="@color/white"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="May" android:textColor="@color/grey_text" android:textSize="11sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="27" android:textColor="@color/black" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tue" android:textColor="@color/grey_text" android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:scrollbars="none">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_card"
                        android:backgroundTint="@color/purple_primary"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="10dp"
                        android:textStyle="bold"
                        android:layout_marginEnd="10dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="To do"
                        android:textColor="@color/purple_primary"
                        android:background="@drawable/bg_card"
                        android:backgroundTint="@color/purple_light"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="10dp"
                        android:textStyle="bold"
                        android:layout_marginEnd="10dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="In Progress"
                        android:textColor="@color/purple_primary"
                        android:background="@drawable/bg_card"
                        android:backgroundTint="@color/purple_light"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="10dp"
                        android:textStyle="bold"
                        android:layout_marginEnd="10dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Completed"
                        android:textColor="@color/purple_primary"
                        android:background="@drawable/bg_card"
                        android:backgroundTint="@color/purple_light"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="10dp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="25dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/shape_card"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp"
                    android:elevation="2dp">
                    <TextView
                        android:id="@+id/cate1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Grocery shopping app design"
                        android:textColor="@color/grey_text"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/icon_bg1"/>
                    <TextView
                        android:id="@+id/title1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Market Research"
                        android:textColor="@color/black"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/cate1"
                        app:layout_constraintEnd_toStartOf="@id/icon_bg1"/>
                    <TextView
                        android:id="@+id/time1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🕒 10:00 AM"
                        android:textColor="@color/purple_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/title1"/>
                    <View
                        android:id="@+id/icon_bg1"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/shape_status_done"
                        android:backgroundTint="#FFDEEF"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_agenda"
                        app:tint="#E91E63"
                        app:layout_constraintStart_toStartOf="@id/icon_bg1"
                        app:layout_constraintEnd_toEndOf="@id/icon_bg1"
                        app:layout_constraintTop_toTopOf="@id/icon_bg1"
                        app:layout_constraintBottom_toBottomOf="@id/icon_bg1"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Done"
                        android:textColor="@color/status_done_text"
                        android:background="@drawable/shape_status_done"
                        android:backgroundTint="@color/status_done_bg"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/shape_card"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp"
                    android:elevation="2dp">
                    <TextView
                        android:id="@+id/cate2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Grocery shopping app design"
                        android:textColor="@color/grey_text"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/icon_bg2"/>
                    <TextView
                        android:id="@+id/title2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Competitive Analysis"
                        android:textColor="@color/black"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/cate2"
                        app:layout_constraintEnd_toStartOf="@id/icon_bg2"/>
                    <TextView
                        android:id="@+id/time2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🕒 12:00 PM"
                        android:textColor="@color/purple_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/title2"/>
                    <View
                        android:id="@+id/icon_bg2"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/shape_status_done"
                        android:backgroundTint="#FFDEEF"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_agenda"
                        app:tint="#E91E63"
                        app:layout_constraintStart_toStartOf="@id/icon_bg2"
                        app:layout_constraintEnd_toEndOf="@id/icon_bg2"
                        app:layout_constraintTop_toTopOf="@id/icon_bg2"
                        app:layout_constraintBottom_toBottomOf="@id/icon_bg2"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="In Progress"
                        android:textColor="@color/status_progress_text"
                        android:background="@drawable/shape_status_done"
                        android:backgroundTint="@color/status_progress_bg"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/shape_card"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp"
                    android:elevation="2dp">
                    <TextView
                        android:id="@+id/cate3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Uber Eats redesign challenge"
                        android:textColor="@color/grey_text"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/icon_bg3"/>
                    <TextView
                        android:id="@+id/title3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Create Low-fidelity Wireframe"
                        android:textColor="@color/black"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/cate3"
                        app:layout_constraintEnd_toStartOf="@id/icon_bg3"/>
                    <TextView
                        android:id="@+id/time3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🕒 07:00 PM"
                        android:textColor="@color/purple_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/title3"/>
                    <View
                        android:id="@+id/icon_bg3"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/shape_status_done"
                        android:backgroundTint="#EBF5FB"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_gallery"
                        app:tint="#3498DB"
                        app:layout_constraintStart_toStartOf="@id/icon_bg3"
                        app:layout_constraintEnd_toEndOf="@id/icon_bg3"
                        app:layout_constraintTop_toTopOf="@id/icon_bg3"
                        app:layout_constraintBottom_toBottomOf="@id/icon_bg3"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="To-do"
                        android:textColor="#3498DB"
                        android:background="@drawable/shape_status_done"
                        android:backgroundTint="#EBF5FB"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/shape_card"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp"
                    android:elevation="2dp">
                    <TextView
                        android:id="@+id/cate4"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="About design sprint"
                        android:textColor="@color/grey_text"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/icon_bg4"/>
                    <TextView
                        android:id="@+id/title4"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="How to pitch a Design Sprint"
                        android:textColor="@color/black"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/cate4"
                        app:layout_constraintEnd_toStartOf="@id/icon_bg4"/>
                    <TextView
                        android:id="@+id/time4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🕒 09:00 PM"
                        android:textColor="@color/purple_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/title4"/>
                    <View
                        android:id="@+id/icon_bg4"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/shape_status_done"
                        android:backgroundTint="#FFF2E6"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_compass"
                        app:tint="#E67E22"
                        app:layout_constraintStart_toStartOf="@id/icon_bg4"
                        app:layout_constraintEnd_toEndOf="@id/icon_bg4"
                        app:layout_constraintTop_toTopOf="@id/icon_bg4"
                        app:layout_constraintBottom_toBottomOf="@id/icon_bg4"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="To-do"
                        android:textColor="#3498DB"
                        android:background="@drawable/shape_status_done"
                        android:backgroundTint="#EBF5FB"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomappbar.BottomAppBar
        android:id="@+id/bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:fabCradleMargin="10dp"
        app:fabCradleRoundedCornerRadius="20dp"
        app:backgroundTint="@color/white">
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:background="@android:color/transparent"
            app:menu="@menu/bottom_nav_menu"
            app:labelVisibilityMode="unlabeled" />
    </com.google.android.material.bottomappbar.BottomAppBar>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/purple_primary"
        app:layout_anchor="@id/bar"
        app:layout_anchorGravity="center" app:tint="@color/white" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>